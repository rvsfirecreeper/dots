#!/usr/bin/env bash

fileindots="$(realpath "$HOME/.scripts/rlmanager")"
cd "$(dirname $fileindots)" || exit 1
cd "$(git rev-parse --show-toplevel)" || exit 1

variable=placeholder

case "$1" in
  opacity|large_font_size|font_size)
    variable="$1"
    ;;
  pill)
    variable="is_pill"
    ;;
  help|"")
    echo "Settings: opacity(0-1 float), large_font_size(int), font_size(int), pill(bool)"
    exit 0
    ;;
esac

value="$2"

if [[ "$variable" == "placeholder" ]]; then
  echo "Unknown setting: $1"
  exit 1
fi

case "$variable" in
  opacity)
    if ! [[ "$value" =~ ^0(\.[0-9]+)?$|^1(\.0+)?$ ]]; then
      echo "opacity must be a float between 0 and 1"
      exit 1
    fi
    ;;
  font_size|large_font_size)
    if ! [[ "$value" =~ ^[0-9]+$ ]]; then
      echo "$variable must be an integer"
      exit 1
    fi
    ;;
  is_pill)
    if [[ "$value" != "true" && "$value" != "false" ]]; then
      echo "pill must be true or false"
      exit 1
    fi
    ;;
esac

sed -i "s/^$variable = .*/$variable = $value/" .dotter/global.toml
dotter deploy
